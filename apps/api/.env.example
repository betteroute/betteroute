# Core
APP_ENV=development
PORT=8080
DATABASE_URL=postgres://localhost:5432/betteroute?sslmode=disable

# URLs
API_URL=http://localhost:8080
WEB_URL=http://localhost:3000

# Email (Resend) — leave blank for dev no-op mode
EMAIL_API_KEY=
EMAIL_FROM=Betteroute <onboarding@resend.dev>

# OAuth — leave blank to disable the provider
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Polar (Merchant of Record) — leave blank to disable billing
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRO_MONTHLY_ID=
POLAR_PRO_YEARLY_ID=
POLAR_TEAM_MONTHLY_ID=
POLAR_TEAM_YEARLY_ID=
POLAR_ENT_YEARLY_ID=
POLAR_SELFHOSTED_YEARLY_ID=



