{
	on_demand_tls {
		ask http://{$API_HOST:localhost}:{$PORT:8080}/internal/domain-check
		interval 2m
		burst 5
	}
}

{$APP_DOMAIN:localhost} {
	@internal {
		path /internal/*
	}
	respond @internal 403

	reverse_proxy {$API_HOST:localhost}:{$PORT:8080}
}

:443 {
	tls {
		on_demand
	}

	@internal {
		path /internal/*
	}
	respond @internal 403
	
	reverse_proxy {$API_HOST:localhost}:{$PORT:8080}
}
